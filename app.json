{
  "expo": {
    "name": "Void-Tech Logistics",
    "slug": "void-tech",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "voidtech",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voidtech.logistics",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.voidtech.logistics"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "340642cf-0fce-4f02-9917-479aab2c2a24"
      }
    }
  }
}
